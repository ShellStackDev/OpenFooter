{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "dist/react",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true
  },
  "include": ["src/react", "src/react-shim.d.ts"]
}
